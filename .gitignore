# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any subdirectory, e.g. workers/chatbot-api)
node_modules/

/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Large Kashmir master (optional — keep locally, use npm run compress:kashmir-review)
public/reviews-videos/Kashmir Keran Tour..mp4

*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — do not ignore committed templates (e.g. .env.example)
.env*
!.env.example

**/.dev.vars

# Cloudflare Wrangler local dev (D1 SQLite, caches, temp bundles)
.wrangler/
**/.wrangler/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare Workers — regenerated locally: cd workers/chatbot-api && npx wrangler types
workers/chatbot-api/worker-configuration.d.ts
